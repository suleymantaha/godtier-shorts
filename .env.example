# GodTier Shorts - Environment Variables Template
# Copy this file to .env and fill in your values

# =============================================================================
# AI Configuration
# =============================================================================


# LM Studio (for local LLM - optional)
LMSTUDIO_HOST=http://localhost:1234




# =============================================================================
# API Keys
# =============================================================================

# YouTube API (optional - for enhanced features)
YOUTUBE_API_KEY=your_youtube_api_key

# LM Studio Api Key (for local LLM - optional)
LM_STUDIO_API_KEY=sk-lm-your-key

# HuggingFace Token (for WhisperX models - optional)
HF_TOKEN=hf_your_huggingface_token

# OpenRouter API Key (for cloud LLM - optional)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxx

# Postiz Public API base URL (self-hosted example)
# POSTIZ_API_BASE_URL=http://localhost:4007/api/public/v1

# Connection surface:
# - managed: paylasimli/global ortam, kullanici API key girmez
# - manual_api_key: tek kullanicili/dev fallback
SOCIAL_CONNECTION_MODE=managed

# Managed OAuth2 (Postiz Developer App)
# POSTIZ_OAUTH_CLIENT_ID=your_postiz_oauth_client_id
# POSTIZ_OAUTH_CLIENT_SECRET=your_postiz_oauth_client_secret
# SOCIAL_OAUTH_CALLBACK_URL=http://localhost:8000/api/social/oauth/callback
# SOCIAL_OAUTH_RETURN_URL=http://localhost:5173
# SOCIAL_OAUTH_STATE_TTL_SECONDS=600

# Optional Postiz API key fallback for local/dev single-user setups
# POSTIZ_API_KEY=your_postiz_api_key

# Social publish encryption secret (required for secure credential storage)
SOCIAL_ENCRYPTION_SECRET=replace-with-strong-random-secret

# Public API base URL for large media URL-import fallback
PUBLIC_APP_URL=http://localhost:8000

# Social scheduler settings
# SOCIAL_SCHEDULER_POLL_SECONDS=10
# SOCIAL_SCHEDULER_CONCURRENCY=3


# =============================================================================
# Server Configuration
# =============================================================================

# API Host
API_HOST=0.0.0.0
API_PORT=8000

# Clerk Authentication (Get this from Clerk Dashboard -> API Keys -> Advanced -> Issuer URL)
CLERK_ISSUER_URL=
CLERK_AUDIENCE=

# Fallback API Bearer tokens (optional, semicolon separated)
# Format: token:role1,role2;token2:role
# API_BEARER_TOKENS=

# Frontend URL (for CORS)
# Must be an absolute http(s) URL, e.g. http://localhost:5173
FRONTEND_URL=http://localhost:5173
# Optional explicit CORS list (comma separated, overrides defaults)
# Each origin must be an absolute http(s) URL
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Request body hard limit in bytes (checked at middleware layer)
# Must be a positive integer and should not be smaller than UPLOAD_MAX_FILE_SIZE
# REQUEST_BODY_HARD_LIMIT_BYTES=5368709120
# Upload limit in bytes (application validation layer)
# Must be a positive integer
# UPLOAD_MAX_FILE_SIZE=5368709120

# Job queue limits per authenticated subject
# MAX_ACTIVE_JOBS_PER_SUBJECT=1
# MAX_PENDING_JOBS_PER_SUBJECT=3

# yt-dlp download protection and progress emission
# YTDLP_DOWNLOAD_IDLE_TIMEOUT_SECONDS=1800
# YTDLP_DOWNLOAD_TOTAL_TIMEOUT_SECONDS=21600
# YTDLP_PROGRESS_MIN_EMIT_INTERVAL_MS=2000

# =============================================================================
# Whisper / faster-whisper performance tuning
# =============================================================================
# Beam size: 1 -> hizli (fp16 GPU), 5 -> kaliteli (yavas)
# WHISPER_BEAM_SIZE=1
# VAD filter: True -> sessizlikleri atlar (hizli), False -> tum sesi tarar
# WHISPER_VAD_FILTER=true
# VAD min silence (ms): VAD acikken kullanilan min sessizlik penceresi
# WHISPER_VAD_MIN_SILENCE_MS=500
# CPU thread sayisi (CTranslate2). 0 -> kutuphane otomatik secsin
# WHISPER_CPU_THREADS=8
# Model paralel worker sayisi (genelde 1)
# WHISPER_NUM_WORKERS=1
# Compute type override (GPU varsayilan: float16, CPU: int8)
# WHISPER_COMPUTE_TYPE_GPU=float16
# WHISPER_COMPUTE_TYPE_CPU=int8

# Ek subprocess arac dizinleri (PATHSEP ile ayrilmis); venv Scripts otomatik bulunur
# BACKEND_TOOL_BIN_DIRS=

# =============================================================================
# Model Paths (optional - defaults are usually fine)
# =============================================================================

# YOLO Model Path
# yolo11x.pt -> en kaliteli / daha yavas; yolo11s.pt -> hizli CUDA dengesi
# YOLO_MODEL_PATH=yolo11s.pt

# Render quality hardening
# shadow -> metadata'da kalite sinyali uretir; enforce -> unsafe ciktilari review'a alir
# LAYOUT_SAFETY_MODE=shadow
# DEBUG_RENDER_ARTIFACTS=0

# Active speaker tracking (single-layout listener-lock guard)
# ACTIVE_SPEAKER_MIN_MOTION_SCORE=0.42
# ACTIVE_SPEAKER_MOTION_MARGIN=0.18
# ACTIVE_SPEAKER_CONFIRMATION_FRAMES=2
# ACTIVE_SPEAKER_CATCHUP_FRAMES=12
# ACTIVE_SPEAKER_MAX_STEP_RATIO=0.055
# ACTIVE_SPEAKER_EMA_ALPHA=0.60

# =============================================================================
# Development Settings
# =============================================================================


# DEBUG mode
DEBUG=false

# Frontend (Vite) — proje kökü .env; npm run dev öncesi doldurun
VITE_CLERK_PUBLISHABLE_KEY=
VITE_CLERK_JWT_TEMPLATE=your-vite-clerk-api
